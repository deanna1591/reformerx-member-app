# Copy to .env.local and fill in. Never commit .env.local.

# Admin dashboard password
ADMIN_PASSWORD=reformerx

# SimplyBook — Custom Features → API
# Use an **API User Key** (not the public key/secret) for the admin API:
# API page → "API User Keys" link → create a key for a user, then:
SIMPLYBOOK_COMPANY=reformerx        # your company login (the subdomain)
SIMPLYBOOK_LOGIN=                   # the SimplyBook user the key belongs to
SIMPLYBOOK_USER_KEY=                # the generated API User Key

# Optional — defaults to https://user-api-v2.simplybook.it
# SIMPLYBOOK_API_BASE=https://user-api-v2.simplybook.it

# Web Push (optional but recommended) — generate once with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@reformerx.cz

# Passes are read from paid invoices' package lines (last 60 days each sync).
# Set to 1 ONCE (locally or one production sync) to backfill 400 days of pass history:
# SIMPLYBOOK_SCAN_INVOICES=1
#
# How far back to import booking history (default 45 days). Run a deep one-time
# backfill locally to populate lifetime class counts, e.g.:
#   SIMPLYBOOK_BOOKING_DAYS=1095 npx tsx scripts/run-sync.ts
# SIMPLYBOOK_BOOKING_DAYS=45

# ---- Supabase persistence (production) ----
# Project settings → API. With these set, all data persists in Supabase.
# Without them (local dev), data lives in .data/db.json as before.
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- In-app booking ----
# Public booking page (used for "Reserve ↗" and the pass shop handoff)
NEXT_PUBLIC_SIMPLYBOOK_BOOKING_URL=https://rezervace.reformerx.cz/v2/
# Set to 1 only AFTER the SimplyBook book() call is verified against this account.
# Until then, Reserve opens the SimplyBook booking page instead of writing bookings.
# SIMPLYBOOK_ALLOW_BOOKING=1

# Studio timezone — all class times are parsed and displayed in this zone,
# regardless of where the server runs (Vercel runs in UTC).
STUDIO_TZ=Europe/Prague

# ---- Member sign-in (passwordless) ----
# Resend API key for sending sign-in codes. Without it, codes print to the server
# log (fine for local testing, not for production).
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=ReformerX <noreply@reformerx.cz>
# Extra salt for hashing sign-in codes (any random string)
# OTP_SECRET=change-me
# Protects the scheduled sync endpoint (/api/cron/sync)
# CRON_SECRET=change-me

# Salt for hashing staff PINs (any random string)
# STAFF_PIN_SECRET=change-me

# How many classes a member may book per day (studio pass rule). Default 1.
# MAX_CLASSES_PER_DAY=1

# Days before a pass expires to send the renewal reminder (default 3)
# RENEWAL_REMINDER_DAYS=3
